// IDEA — OpenClaw Configuration Template
// Maintained in: idea/openclaw/openclaw.json
// Deployed to:   ~/.openclaw/openclaw.json  (on the Pi, inside the container mount)
//
// The setup script (idea/scripts/setup.sh) substitutes {{TELEGRAM_BOT_TOKEN}}
// and merges this config with the auto-generated gateway token.
//
// Agent IDs are stable UUIDs tied to Mission Control board IDs — do not change
// them unless you are also recreating the MC boards.
//
// Telegram group IDs are IDEA-specific and should not change between installs.
{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m"
      }
    },
    "list": [
      // Axle — Engine Dev
      {
        "id": "lead-6bddb9d2-c06f-444d-8b18-b517aeaa6aa8",
        "name": "Axle",
        "workspace": "/home/node/workspace/agents/agent-engine-dev",
        "agentDir": "/root/.openclaw/agents/lead-6bddb9d2-c06f-444d-8b18-b517aeaa6aa8/agent",
        "heartbeat": { "every": "0m", "includeReasoning": false, "target": "last" }
      },
      // Pixel — Console Dev
      {
        "id": "lead-ac508766-e9e3-48a0-b6a5-54c6ffcdc1a3",
        "name": "Pixel",
        "workspace": "/home/node/workspace/agents/agent-console-dev",
        "agentDir": "/root/.openclaw/agents/lead-ac508766-e9e3-48a0-b6a5-54c6ffcdc1a3/agent",
        "heartbeat": { "every": "0m", "includeReasoning": false, "target": "last" }
      },
      // Beacon — Site Dev
      {
        "id": "lead-7cc2a1cf-fa22-485f-b842-bb22cb758257",
        "name": "Beacon",
        "workspace": "/home/node/workspace/agents/agent-site-dev",
        "agentDir": "/root/.openclaw/agents/lead-7cc2a1cf-fa22-485f-b842-bb22cb758257/agent",
        "heartbeat": { "every": "0m", "includeReasoning": false, "target": "last" }
      },
      // Marco — Programme Manager
      {
        "id": "lead-3f1be9c8-87e7-4a5d-9d3b-99756c35e3a9",
        "name": "Marco",
        "workspace": "/home/node/workspace/agents/agent-programme-manager",
        "agentDir": "/root/.openclaw/agents/lead-3f1be9c8-87e7-4a5d-9d3b-99756c35e3a9/agent",
        "heartbeat": { "every": "0m", "includeReasoning": false, "target": "last" }
      },
      // Atlas — Operations Manager (COO)
      {
        "id": "operations-manager",
        "name": "Atlas",
        "workspace": "/home/node/workspace/agents/agent-operations-manager"
      }
    ]
  },

  // Map each Telegram group to its agent
  "bindings": [
    {
      "agentId": "lead-6bddb9d2-c06f-444d-8b18-b517aeaa6aa8",
      "match": { "channel": "telegram", "peer": { "kind": "group", "id": "-5146184666" } }
    },
    {
      "agentId": "lead-ac508766-e9e3-48a0-b6a5-54c6ffcdc1a3",
      "match": { "channel": "telegram", "peer": { "kind": "group", "id": "-5187034968" } }
    },
    {
      "agentId": "lead-7cc2a1cf-fa22-485f-b842-bb22cb758257",
      "match": { "channel": "telegram", "peer": { "kind": "group", "id": "-5139661372" } }
    },
    {
      "agentId": "lead-3f1be9c8-87e7-4a5d-9d3b-99756c35e3a9",
      "match": { "channel": "telegram", "peer": { "kind": "group", "id": "-5141459717" } }
    },
    {
      "agentId": "operations-manager",
      "match": { "channel": "telegram", "peer": { "kind": "group", "id": "-5105695997" } }
    }
  ],

  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },

  "channels": {
    "defaults": {
      "heartbeat": {
        "showOk": false,
        "showAlerts": true,
        "useIndicator": true
      }
    },
    "telegram": {
      "dmPolicy": "allowlist",
      "botToken": "{{TELEGRAM_BOT_TOKEN}}",
      "groups": {
        "*": { "requireMention": false }
      },
      // DM allowlist: Koen's Telegram user ID
      "allowFrom": [
        "8320646468",
        "-5146184666",
        "-5187034968",
        "-5139661372",
        "-5286995682",
        "-5141459717",
        "-5105695997"
      ],
      "groupAllowFrom": [
        "8320646468"
      ],
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    }
  },

  // gateway.remote.token is auto-generated by docker-setup.sh
  // and merged in by setup.sh — do not set it here
  "gateway": {
    "trustedProxies": [ "127.0.0.1" ]
  },

  "skills": {
    "load": {
      "extraDirs": [ "/home/node/workspace/skills" ]
    }
  },

  "plugins": {
    "entries": {
      "telegram": { "enabled": true }
    }
  }
}
