# IDEA — OpenClaw credential template
# Copy this file to .env and fill in your values.
# The setup script (idea/scripts/setup.sh) does this automatically.
#
# NEVER commit .env to git — it is listed in .gitignore.

# ── Anthropic ─────────────────────────────────
# Used by all agents for LLM calls
ANTHROPIC_API_KEY=

# ── Telegram ──────────────────────────────────
# Bot token for @Idea911Bot — connects all agent groups
TELEGRAM_BOT_TOKEN=

# ── GitHub ────────────────────────────────────
# Personal access token — used by agents for git push (PRs, memory commits)
# Required scopes: repo (full)
GITHUB_TOKEN=

# ── Mission Control ───────────────────────────
# Auth token for the MC REST API — generated by MC on first run
# Leave blank; setup.sh reads it from the running MC container
AUTH_TOKEN=
